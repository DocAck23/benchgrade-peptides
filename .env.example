# --- Supabase ---
# Get these from your Supabase project settings → API.
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...

# Service role — SERVER ONLY. Never expose to the browser.
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# --- Resend ---
# Get from resend.com → API Keys.
RESEND_API_KEY=re_...
RESEND_FROM_EMAIL=admin@benchgradepeptides.com
RESEND_FROM_NAME="Bench Grade Peptides"

# --- Site ---
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# --- Admin ---
ADMIN_NOTIFICATION_EMAIL=admin@benchgradepeptides.com
ADMIN_PASSWORD=change-me-to-a-strong-passphrase

# --- Compliance ---
COMPLIANCE_LINT_STRICT=true

# --- Payment methods ---
# All four share the same principle: missing env vars = the method is
# hidden from checkout entirely (no broken button). Set these once the
# account is live and funds can clear.

# Wire + ACH (Relay Business). Both share these credentials.
WIRE_BENEFICIARY="Bench Grade Peptides LLC"
WIRE_BANK="Relay Financial"
WIRE_ROUTING=084106768
WIRE_ACCOUNT=0000000000

# Zelle (Chase Business). ID is the @handle or phone/email your Zelle is
# registered under. Bench Grade's is `benchgrade`.
ZELLE_ID=benchgrade

# Crypto (NOWPayments). Scaffolded in Commit 3 webhook handler; leave
# unset to hide the crypto option at checkout until the key is minted.
NOWPAYMENTS_API_KEY=
NOWPAYMENTS_IPN_SECRET=
