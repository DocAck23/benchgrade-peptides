# --- Supabase ---
# Get these from your Supabase project settings → API.
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...

# Service role — SERVER ONLY. Never expose to the browser.
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# --- Resend ---
# Get from resend.com → API Keys.
RESEND_API_KEY=re_...

# Sender identity for transactional email
RESEND_FROM_EMAIL=admin@benchgradepeptides.com
RESEND_FROM_NAME="Bench Grade Peptides"

# --- Site ---
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# --- Admin ---
# Email for internal order notifications and system alerts
ADMIN_NOTIFICATION_EMAIL=admin@benchgradepeptides.com

# --- Compliance ---
# If set, the CI compliance linter fails the build on any banned-terms match
COMPLIANCE_LINT_STRICT=true
